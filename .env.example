# PathWave 백엔드 운영 환경변수 템플릿 (2026-05-29)
#
# 운영(PATHWAVE_ENV=production) 부팅 시 app.py:48 _validate_production_env() 가
# 필수 키 누락을 검출해 부팅을 차단한다. 본 파일을 .env 또는 systemd/Docker
# 환경변수로 옮긴 뒤 실제 값으로 채워 사용.
#
# ⚠️ 본 파일은 템플릿 — 실 값은 .env 등 gitignore 된 파일에 두고 절대 커밋 금지.

# ── 모드 ─────────────────────────────────────────────────────────────────────
PATHWAVE_ENV=production                       # development / staging / production
FLASK_DEBUG=0                                 # 운영은 반드시 0

# ── 보안 키 (필수, 운영 dev 기본값 금지) ────────────────────────────────────
# SECRET_KEY  : JWT 서명 키. 32바이트 이상 랜덤.
#               생성: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=__CHANGE_ME__random_hex_32bytes_or_more__

# PATHWAVE_AES_KEY : WiFi 비밀번호 + 빌링키(pg_key) + 신청유닛 비번 암호화 키.
#                    base64 인코딩된 32바이트.
#                    생성: python -c "import os,base64; print(base64.b64encode(os.urandom(32)).decode())"
# ⚠️ 한 번 정한 키는 절대 변경 금지(기존 암호화 데이터 복호화 불가).
PATHWAVE_AES_KEY=__CHANGE_ME__base64_32bytes__

# CORS_ORIGINS : 콤마 구분된 화이트리스트. 운영 도메인만.
CORS_ORIGINS=https://app.pathwave.kr,https://provider.pathwave.kr,https://admin.pathwave.kr

# ── 데이터베이스 (필수, PostgreSQL) ──────────────────────────────────────────
# postgresql:// 또는 postgres:// 로 시작해야 함. sqlite 는 운영 불가.
DATABASE_URL=postgresql://pathwave_user:__CHANGE_ME__@db.internal:5432/pathwave_prod

# ── PG (결제) — 제로페이 + 토스 폴백 (2026-06-05 사용자 결정) ────────────
# PG_PROVIDER 값: sim | toss | zeropay | fallback
#   fallback 시 FALLBACK_PRIMARY 1차, 실패하면 FALLBACK_SECONDARY 2차 자동 시도.
#   payments.gateway 에 실제 처리 PG 기록, payments.fallback_from 에 원래 시도 기록.
PG_PROVIDER=fallback                          # sim / toss / zeropay / fallback
FALLBACK_PRIMARY=zeropay                      # 1차 PG (수수료 0% 매장 결제 우선)
FALLBACK_SECONDARY=toss                       # 2차 PG (외국인 카드 / 1차 실패 시)
# 토스 — 빌링키 자동결제 + 카드 1회 결제
TOSS_SECRET_KEY=__CHANGE_ME__toss_secret_key__
# TOSS_API_BASE=                              # 기본 https://api.tosspayments.com
# 제로페이 — 가맹점 사양 확정 후 키 주입. 키 미설정 시 stub 동작(개발/CI).
ZEROPAY_MID=
ZEROPAY_API_KEY=
# ZEROPAY_API_BASE=                           # 기본 https://api.zeropay.or.kr

# ── 이메일 (sendgrid 또는 smtp) ──────────────────────────────────────────────
EMAIL_PROVIDER=sendgrid                       # sendgrid / smtp / stub
SENDGRID_API_KEY=__CHANGE_ME__SG.xxxxx__
# SMTP_USER=__CHANGE_ME__
# SMTP_PASS=__CHANGE_ME__
EMAIL_FROM=PathWave <no-reply@pathwave.app>

# ── 소셜 로그인 (2026-06-09) ────────────────────────────────────────────────
# Google / Apple / Facebook = Firebase Auth ID Token 검증으로 통합 (FIREBASE_CREDENTIALS 사용).
# Kakao / Naver = 자체 OAuth (백엔드가 직접 토큰 교환).
# 키 미설정 시 routes/social_kakao.py / social_naver.py 가 stub 응답으로 동작.
KAKAO_REST_API_KEY=__CHANGE_ME__kakao_rest_api_key__
# KAKAO_CLIENT_SECRET=__OPTIONAL__                # Kakao 보안 옵션 켤 때만
NAVER_CLIENT_ID=__CHANGE_ME__naver_client_id__
NAVER_CLIENT_SECRET=__CHANGE_ME__naver_client_secret__

# ── 푸시 — FCM (Android+iOS) 권장 ───────────────────────────────────────────
PUSH_PROVIDER=fcm                             # stub / apns / fcm / multi
# Firebase Admin SDK 자격증명 (서비스 계정 JSON 경로)
FIREBASE_CREDENTIALS=/etc/pathwave/firebase-admin-sdk.json
# APNs 직접 사용 시 (PUSH_PROVIDER=apns 또는 multi):
# APNS_KEY_PATH=/etc/pathwave/AuthKey_XXXXXXXXXX.p8
# APNS_KEY_ID=__CHANGE_ME__
# APNS_TEAM_ID=__CHANGE_ME__
# APNS_BUNDLE_ID=com.triggersoft.pathwave

# ── 번역 (운영 필수 — 채팅 자동번역) ────────────────────────────────────────
TRANSLATION_PROVIDER=google                   # stub / google
TRANSLATION_API_KEY=__CHANGE_ME__google_translate_api_key__
# DEEPL_API_KEY=__CHANGE_ME__deepl_api_key__  # DeepL 사용 시 (i18n 일괄 번역 스크립트용)

# ── SMS / 카카오 알림톡 (SolAPI) ────────────────────────────────────────────
SOLAPI_API_KEY=__CHANGE_ME__
SOLAPI_API_SECRET=__CHANGE_ME__

# ── 슈퍼어드민 초기 부트스트랩 (1회만, 가입 후 비활성 권장) ─────────────────
# BOOTSTRAP_SUPER_ADMIN_EMAIL=admin@pathwave.app
# BOOTSTRAP_SUPER_ADMIN_PASSWORD=__CHANGE_ME__strong_password__

# ── 모니터링 (Sentry) — 선택, DSN 미주입 시 자동 no-op ──────────────────────
SENTRY_DSN=                                   # 예: https://xxxx@oXXXX.ingest.sentry.io/xxxx
SENTRY_TRACES_SAMPLE_RATE=0.1                 # 0.0~1.0
GIT_SHA=                                      # 배포 시 git rev-parse HEAD 주입 (Sentry release 태그)

# ── 추가 운영 설정 ──────────────────────────────────────────────────────────
# RATELIMIT_STORAGE_URI=redis://redis.internal:6379/0    # flask-limiter 운영 storage
# 도메인/HTTPS 는 reverse proxy(Nginx / Cloudflare) 에서 처리 권장.
