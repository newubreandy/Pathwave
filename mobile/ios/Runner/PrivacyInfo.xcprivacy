<?xml version="1.0" encoding="UTF-8"?>
<!--
  PathWave 앱 Privacy Manifest (iOS) — Apple App Store 심사 필수.
  https://developer.apple.com/documentation/bundleresources/privacy_manifest_files

  v1 스코프
  ────────
  - 광고/추적 미사용 (NSPrivacyTracking=false)
  - 수집 데이터: 이메일/이름/전화/위치/사진/디바이스ID/사용자ID/결제/지원채팅
  - 모두 'App Functionality' 목적 — 결제는 'Personalization' 도 추가
  - Apple 'Required Reason API' 4종에 사유 명시 (UserDefaults / FileTimestamp /
    DiskSpace / SystemBootTime)

  업데이트 가이드
  ─────────────
  - 새 SDK 추가 시 그 SDK 의 PrivacyInfo.xcprivacy 를 함께 확인.
  - 추적 도메인(애드네트워크/분석)을 활성화하면 NSPrivacyTracking=true 로 변경
    + NSPrivacyTrackingDomains 배열에 도메인 등록.
  - 사용자가 ATT(앱 추적 투명성) 거부해도 작동해야 함.
-->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- ────────────────────────────────────────────────────────────── -->
    <!-- 1. 추적 (Tracking) — PathWave v1 = 광고/추적 SDK 미사용 -->
    <!-- ────────────────────────────────────────────────────────────── -->
    <key>NSPrivacyTracking</key>
    <false/>
    <key>NSPrivacyTrackingDomains</key>
    <array/>

    <!-- ────────────────────────────────────────────────────────────── -->
    <!-- 2. 수집 데이터 (Collected Data Types) -->
    <!-- 각 항목: NSPrivacyCollectedDataType / Linked / Tracking / Purposes -->
    <!-- ────────────────────────────────────────────────────────────── -->
    <key>NSPrivacyCollectedDataTypes</key>
    <array>
        <!-- Email Address — 회원가입/로그인/공지/약관 변경 안내 -->
        <dict>
            <key>NSPrivacyCollectedDataType</key>
            <string>NSPrivacyCollectedDataTypeEmailAddress</string>
            <key>NSPrivacyCollectedDataTypeLinked</key>
            <true/>
            <key>NSPrivacyCollectedDataTypeTracking</key>
            <false/>
            <key>NSPrivacyCollectedDataTypePurposes</key>
            <array>
                <string>NSPrivacyCollectedDataTypePurposeAppFunctionality</string>
            </array>
        </dict>

        <!-- Name — 회원 이름 / 매장 담당자 -->
        <dict>
            <key>NSPrivacyCollectedDataType</key>
            <string>NSPrivacyCollectedDataTypeName</string>
            <key>NSPrivacyCollectedDataTypeLinked</key>
            <true/>
            <key>NSPrivacyCollectedDataTypeTracking</key>
            <false/>
            <key>NSPrivacyCollectedDataTypePurposes</key>
            <array>
                <string>NSPrivacyCollectedDataTypePurposeAppFunctionality</string>
            </array>
        </dict>

        <!-- Phone Number — 사장 가입/연락처 -->
        <dict>
            <key>NSPrivacyCollectedDataType</key>
            <string>NSPrivacyCollectedDataTypePhoneNumber</string>
            <key>NSPrivacyCollectedDataTypeLinked</key>
            <true/>
            <key>NSPrivacyCollectedDataTypeTracking</key>
            <false/>
            <key>NSPrivacyCollectedDataTypePurposes</key>
            <array>
                <string>NSPrivacyCollectedDataTypePurposeAppFunctionality</string>
            </array>
        </dict>

        <!-- Precise Location — BLE 비콘 감지 + 근처 매장 안내 -->
        <dict>
            <key>NSPrivacyCollectedDataType</key>
            <string>NSPrivacyCollectedDataTypePreciseLocation</string>
            <key>NSPrivacyCollectedDataTypeLinked</key>
            <true/>
            <key>NSPrivacyCollectedDataTypeTracking</key>
            <false/>
            <key>NSPrivacyCollectedDataTypePurposes</key>
            <array>
                <string>NSPrivacyCollectedDataTypePurposeAppFunctionality</string>
            </array>
        </dict>

        <!-- Photos or Videos — 프로필 사진 / 매장 사진 첨부 -->
        <dict>
            <key>NSPrivacyCollectedDataType</key>
            <string>NSPrivacyCollectedDataTypePhotosorVideos</string>
            <key>NSPrivacyCollectedDataTypeLinked</key>
            <true/>
            <key>NSPrivacyCollectedDataTypeTracking</key>
            <false/>
            <key>NSPrivacyCollectedDataTypePurposes</key>
            <array>
                <string>NSPrivacyCollectedDataTypePurposeAppFunctionality</string>
            </array>
        </dict>

        <!-- Device ID — FCM/APNs 푸시 토큰 -->
        <dict>
            <key>NSPrivacyCollectedDataType</key>
            <string>NSPrivacyCollectedDataTypeDeviceID</string>
            <key>NSPrivacyCollectedDataTypeLinked</key>
            <true/>
            <key>NSPrivacyCollectedDataTypeTracking</key>
            <false/>
            <key>NSPrivacyCollectedDataTypePurposes</key>
            <array>
                <string>NSPrivacyCollectedDataTypePurposeAppFunctionality</string>
            </array>
        </dict>

        <!-- User ID — PathWave 서버 user_id (인증 토큰 안에 들어감) -->
        <dict>
            <key>NSPrivacyCollectedDataType</key>
            <string>NSPrivacyCollectedDataTypeUserID</string>
            <key>NSPrivacyCollectedDataTypeLinked</key>
            <true/>
            <key>NSPrivacyCollectedDataTypeTracking</key>
            <false/>
            <key>NSPrivacyCollectedDataTypePurposes</key>
            <array>
                <string>NSPrivacyCollectedDataTypePurposeAppFunctionality</string>
            </array>
        </dict>

        <!-- Purchase History — 구독 결제 / 영수증 -->
        <dict>
            <key>NSPrivacyCollectedDataType</key>
            <string>NSPrivacyCollectedDataTypePurchaseHistory</string>
            <key>NSPrivacyCollectedDataTypeLinked</key>
            <true/>
            <key>NSPrivacyCollectedDataTypeTracking</key>
            <false/>
            <key>NSPrivacyCollectedDataTypePurposes</key>
            <array>
                <string>NSPrivacyCollectedDataTypePurposeAppFunctionality</string>
            </array>
        </dict>

        <!-- Customer Support — 1:1 매장 채팅 메시지 / 신고 / 문의 -->
        <dict>
            <key>NSPrivacyCollectedDataType</key>
            <string>NSPrivacyCollectedDataTypeCustomerSupport</string>
            <key>NSPrivacyCollectedDataTypeLinked</key>
            <true/>
            <key>NSPrivacyCollectedDataTypeTracking</key>
            <false/>
            <key>NSPrivacyCollectedDataTypePurposes</key>
            <array>
                <string>NSPrivacyCollectedDataTypePurposeAppFunctionality</string>
            </array>
        </dict>
    </array>

    <!-- ────────────────────────────────────────────────────────────── -->
    <!-- 3. Required Reason API (Apple 2024-Spring 이후 의무화) -->
    <!--   - 각 API 별로 'Reason Code' 명시 필요. -->
    <!--   - 사유 코드 목록: https://developer.apple.com/documentation/bundleresources/privacy_manifest_files/describing_use_of_required_reason_api -->
    <!-- ────────────────────────────────────────────────────────────── -->
    <key>NSPrivacyAccessedAPITypes</key>
    <array>
        <!-- UserDefaults — shared_preferences (Flutter 플러그인) 사용. CA92.1 = 본 앱 UserDefaults 만. -->
        <dict>
            <key>NSPrivacyAccessedAPIType</key>
            <string>NSPrivacyAccessedAPICategoryUserDefaults</string>
            <key>NSPrivacyAccessedAPITypeReasons</key>
            <array>
                <string>CA92.1</string>
            </array>
        </dict>

        <!-- File Timestamp — 캐시/sqflite DB 파일 시간 (디스플레이/세션 만료 판단). -->
        <dict>
            <key>NSPrivacyAccessedAPIType</key>
            <string>NSPrivacyAccessedAPICategoryFileTimestamp</string>
            <key>NSPrivacyAccessedAPITypeReasons</key>
            <array>
                <string>C617.1</string>
            </array>
        </dict>

        <!-- System Boot Time — 네트워크 응답시간 / 세션 idle 측정. -->
        <dict>
            <key>NSPrivacyAccessedAPIType</key>
            <string>NSPrivacyAccessedAPICategorySystemBootTime</string>
            <key>NSPrivacyAccessedAPITypeReasons</key>
            <array>
                <string>35F9.1</string>
            </array>
        </dict>

        <!-- Disk Space — 매장 사진/캐시 쓰기 전 가용 공간 확인. -->
        <dict>
            <key>NSPrivacyAccessedAPIType</key>
            <string>NSPrivacyAccessedAPICategoryDiskSpace</string>
            <key>NSPrivacyAccessedAPITypeReasons</key>
            <array>
                <string>E174.1</string>
            </array>
        </dict>
    </array>
</dict>
</plist>
